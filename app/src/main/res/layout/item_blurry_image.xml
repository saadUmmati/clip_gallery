<?xml version="1.0" encoding="utf-8"?>
<com.example.gallery.app.ui.widget.SquareFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp">

    <!-- Thumbnail image -->
    <ImageView
        android:id="@+id/thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@color/surface_elevated" />

    <!-- Selection Checkbox in top-left -->
    <CheckBox
        android:id="@+id/checkbox"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|start"
        android:layout_margin="4dp"
        android:buttonTint="@color/accent_blue"
        android:clickable="false"
        android:focusable="false" />

    <!-- Gradient overlay for text -->
    <View
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_overlay" />

    <!-- Sharpness Score / badge at bottom -->
    <TextView
        android:id="@+id/sharpnessScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:textColor="@color/text_primary"
        android:textSize="10sp"
        android:shadowColor="#000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="1" />

    <!-- Hidden elements kept for binding compatibility -->
    <TextView
        android:id="@+id/fileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <TextView
        android:id="@+id/fileSize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</com.example.gallery.app.ui.widget.SquareFrameLayout>
